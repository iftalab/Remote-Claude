# Telegram Bot Configuration

# Comma-separated list of allowed Telegram user IDs
# Get your ID by messaging @userinfobot on Telegram
ALLOWED_IDS=123456789,987654321

# Execution timeout for Claude CLI commands (in milliseconds)
# Default: 120000 (2 minutes)
EXEC_TIMEOUT_MS=120000

# Response idle timeout for persistent Claude processes (in milliseconds)
# How long to wait for more output before considering response complete
# Default: 3000 (3 seconds)
RESPONSE_IDLE_MS=3000

# Allowed tools for Claude CLI
# Comma-separated list of tools Claude can use
CLAUDE_TOOLS=Bash,Read,Write,Edit,Glob,Grep
